# ============ AMPHIBIAN OS - CONFIGURACION ============
# Copia este archivo a server/.env y llena lo que tengas.
# TODO es opcional excepto DATABASE_URL. Lo que no llenes, queda apagado.

DATABASE_URL="file:./amphibian.db"
PORT=4000

# ---------- IA (capa portable) ----------
# Proveedor activo: anthropic | openai | gemini | ollama
AI_PROVIDER=anthropic

# Claves (solo la del proveedor activo es necesaria)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# Para APIs OpenAI-compatibles (DeepSeek, Groq, Together, etc) cambia el base URL:
OPENAI_BASE_URL=https://api.openai.com/v1
OLLAMA_BASE_URL=http://localhost:11434

# Modelos por nivel (cheap = transcripcion/clasificacion, standard = entidades/hipotesis, deep = analisis critico)
# Defaults razonables por proveedor ya vienen en el codigo; sobreescribe si quieres.
MODEL_CHEAP=
MODEL_STANDARD=
MODEL_DEEP=

# ---------- Telegram (captura desde el celular) ----------
TELEGRAM_BOT_TOKEN=
# Tu chat id (el bot te lo dice la primera vez que le escribes /start)
TELEGRAM_CHAT_ID=

# ---------- Google (Sheets + Calendar + Drive) ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/google/callback
# ID del spreadsheet donde sincronizar (se crea solo si lo dejas vacio)
GOOGLE_SHEET_ID=

# ---------- Obsidian ----------
# Ruta ABSOLUTA a tu vault. Ej: /Users/pancho/Obsidian/MiVault
OBSIDIAN_VAULT_PATH=

# ---------- WhatsApp via Twilio (opcional, ver docs/WHATSAPP_SETUP.md) ----------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ---------- Recordatorios ----------
# critical = solo criticos | all = todos | morning = lista a las 9am
REMINDER_MODE=critical
